<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stream Player</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/hls.js/1.5.7/hls.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js"></script>
<style>
  :root {
    --bg:#0a0a0f; --surface:#111118; --surface2:#18181f; --border:#1e1e2e;
    --accent:#6c63ff; --accent2:#a78bfa; --text:#e2e8f0; --muted:#64748b;
    --ok:#4ade80; --err:#f87171; --warn:#fb923c;
    --tv:#f59e42; --rock:#38bdf8; --vidzee:#c084fc;
    --mono:'JetBrains Mono','Fira Code',monospace;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;min-height:100vh;}
  body::before{content:'';position:fixed;inset:0;
    background-image:linear-gradient(rgba(108,99,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(108,99,255,.025) 1px,transparent 1px);
    background-size:40px 40px;pointer-events:none;z-index:0;}

  header{position:relative;z-index:1;padding:13px 20px;border-bottom:1px solid var(--border);
    display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
  .logo-dot{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,#6c63ff,#a78bfa);
    display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;}
  header h1{font-size:.95rem;font-weight:700;letter-spacing:.3px;color:var(--accent2);}
  #hdr-status{font-size:.7rem;color:var(--muted);margin-left:auto;}

  .wrap{position:relative;z-index:1;display:grid;grid-template-columns:1fr 360px;height:calc(100vh - 51px);}
  @media(max-width:900px){.wrap{grid-template-columns:1fr;grid-template-rows:auto 1fr;}}

  .player-side{display:flex;flex-direction:column;padding:14px;gap:10px;overflow-y:auto;}

  .url-bar{display:flex;gap:6px;}
  .url-bar input{flex:1;background:var(--surface);border:1px solid var(--border);color:var(--text);
    padding:9px 12px;border-radius:8px;font-size:.8rem;font-family:var(--mono);outline:none;}
  .url-bar input:focus{border-color:var(--accent);}
  .url-bar select{background:var(--surface);border:1px solid var(--border);color:var(--text);
    padding:9px 7px;border-radius:8px;font-size:.78rem;outline:none;cursor:pointer;}
  .url-bar button{background:var(--accent);color:#fff;border:none;border-radius:8px;
    padding:9px 15px;font-size:.8rem;font-weight:600;cursor:pointer;white-space:nowrap;}
  .url-bar button:hover{opacity:.88;}

  .adv-toggle{font-size:.7rem;color:var(--muted);cursor:pointer;user-select:none;
    display:flex;align-items:center;gap:4px;width:fit-content;}
  .adv-toggle:hover{color:var(--accent2);}
  .adv-toggle .arr{transition:transform .2s;display:inline-block;}
  .adv-toggle.open .arr{transform:rotate(90deg);}
  .adv-section{display:none;background:var(--surface);border:1px solid var(--border);
    border-radius:8px;padding:10px 12px;flex-direction:column;gap:7px;}
  .adv-section.visible{display:flex;}
  .adv-row{display:flex;align-items:center;gap:8px;}
  .adv-row label{font-size:.7rem;color:var(--muted);width:52px;flex-shrink:0;}
  .adv-row input{flex:1;background:var(--bg);border:1px solid var(--border);color:var(--text);
    padding:6px 9px;border-radius:6px;font-size:.76rem;font-family:var(--mono);outline:none;}
  .adv-row input:focus{border-color:var(--accent);}
  .adv-note{font-size:.65rem;color:var(--muted);}

  .media-wrap{position:relative;background:#000;border-radius:12px;overflow:hidden;aspect-ratio:16/9;width:100%;flex-shrink:0;}
  video{width:100%;height:100%;display:block;background:#000;}
  #iframe-player{width:100%;height:100%;border:none;display:none;background:#000;}
  .video-overlay{position:absolute;inset:0;display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:10px;pointer-events:none;background:rgba(0,0,0,.6);}
  .video-overlay.hidden{display:none;}
  .spinner{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--accent);
    border-radius:50%;animation:spin .7s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .overlay-msg{font-size:.78rem;color:var(--muted);text-align:center;padding:0 16px;}

  .status-bar{font-size:.7rem;color:var(--muted);display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
  .dot{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:3px;}
  .dot.ok{background:var(--ok);}.dot.err{background:var(--err);}.dot.warn{background:var(--warn);}
  .mbadge{font-size:.6rem;font-weight:700;border-radius:4px;padding:2px 6px;}
  .mb-hls{background:#2a1f0a;color:var(--warn);}.mb-mp4{background:#0a2a14;color:var(--ok);}
  .mb-embed{background:#0a1f2a;color:#38bdf8;}.mb-txt{background:#1a1535;color:var(--accent2);}
  .mb-dash{background:#1a0a2a;color:#c084fc;}.mb-playlist{background:#1a1535;color:var(--accent2);}

  .source-panel{border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;}
  @media(max-width:900px){.source-panel{border-left:none;border-top:1px solid var(--border);max-height:50vh;}}

  .panel-head{padding:10px 13px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:6px;flex-wrap:wrap;flex-shrink:0;}
  .panel-head h2{font-size:.8rem;font-weight:700;}
  .ph-cnt{background:var(--accent);color:#fff;font-size:.6rem;font-weight:700;border-radius:20px;padding:2px 8px;}
  .fetch-bar{display:flex;gap:5px;flex:1;min-width:180px;}
  .fetch-bar input{flex:1;background:var(--bg);border:1px solid var(--border);color:var(--text);
    padding:6px 9px;border-radius:7px;font-size:.76rem;font-family:var(--mono);outline:none;min-width:0;}
  .fetch-bar input:focus{border-color:var(--accent);}
  .fetch-bar select{background:var(--bg);border:1px solid var(--border);color:var(--text);
    padding:6px 5px;border-radius:7px;font-size:.74rem;outline:none;}
  .fetch-bar button{border:none;border-radius:7px;padding:6px 11px;font-size:.74rem;font-weight:700;
    cursor:pointer;color:#fff;background:var(--accent);white-space:nowrap;}
  .fetch-bar button:hover{opacity:.88;}
  .fetch-bar button:disabled{opacity:.4;cursor:not-allowed;}

  /* Episode input section — absolute episode mode */
  .ep-strip{display:none;padding:6px 13px;border-bottom:1px solid var(--border);gap:5px;flex-shrink:0;flex-direction:column;}
  .ep-strip.visible{display:flex;}

  .ep-mode-tabs{display:flex;gap:0;border-radius:7px;overflow:hidden;border:1px solid var(--border);width:fit-content;margin-bottom:4px;}
  .ep-mode-tab{padding:4px 12px;font-size:.68rem;font-weight:600;cursor:pointer;color:var(--muted);background:var(--bg);border:none;transition:all .12s;}
  .ep-mode-tab.active{background:var(--accent);color:#fff;}
  .ep-mode-tab:hover:not(.active){color:var(--text);}

  .ep-manual-row{display:flex;gap:5px;}
  .ep-manual-row input{flex:1;background:var(--surface);border:1px solid var(--border);color:var(--text);
    padding:5px 8px;border-radius:6px;font-size:.74rem;outline:none;}
  .ep-manual-row input:focus{border-color:var(--accent);}

  .ep-abs-row{display:flex;gap:5px;align-items:center;}
  .ep-abs-row input{flex:1;background:var(--surface);border:1px solid var(--border);color:var(--text);
    padding:5px 8px;border-radius:6px;font-size:.74rem;outline:none;}
  .ep-abs-row input:focus{border-color:var(--accent);}
  .ep-abs-row button{background:var(--surface2);border:1px solid var(--border);color:var(--accent2);
    padding:5px 9px;border-radius:6px;font-size:.7rem;font-weight:700;cursor:pointer;white-space:nowrap;}
  .ep-abs-row button:hover{border-color:var(--accent);color:var(--accent);}
  .ep-abs-row button:disabled{opacity:.4;cursor:not-allowed;}

  .ep-detect-result{font-size:.65rem;color:var(--ok);display:none;padding:2px 0;}
  .ep-detect-result.visible{display:block;}
  .ep-detect-err{font-size:.65rem;color:var(--err);display:none;padding:2px 0;}
  .ep-detect-err.visible{display:block;}

  .src-chips{display:flex;gap:5px;padding:7px 13px;border-bottom:1px solid var(--border);flex-wrap:wrap;flex-shrink:0;}
  .src-chip{font-size:.62rem;font-weight:700;padding:3px 8px;border-radius:20px;border:1px solid var(--border);
    background:var(--surface2);color:var(--muted);display:flex;align-items:center;gap:4px;}
  .src-chip .chip-dot{width:5px;height:5px;border-radius:50%;background:var(--muted);}
  .src-chip.pending .chip-dot{background:var(--warn);animation:blink .8s infinite alternate;}
  .src-chip.done    .chip-dot{background:var(--ok);}
  .src-chip.err     .chip-dot{background:var(--err);}
  @keyframes blink{to{opacity:.3;}}

  .filter-tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0;overflow-x:auto;}
  .filter-tab{padding:7px 10px;font-size:.65rem;font-weight:600;cursor:pointer;color:var(--muted);
    border-bottom:2px solid transparent;white-space:nowrap;transition:all .12s;}
  .filter-tab:hover{color:var(--text);}
  .filter-tab.active{color:var(--accent2);border-bottom-color:var(--accent);}

  .stream-list{flex:1;overflow-y:auto;padding:7px 5px;display:flex;flex-direction:column;gap:3px;}
  .stream-list:empty::after{content:"No streams loaded.";display:block;text-align:center;
    color:var(--muted);font-size:.74rem;padding:26px 0;}

  .server-group{margin-bottom:4px;}
  .server-label{font-size:.62rem;font-weight:700;color:var(--muted);text-transform:uppercase;
    letter-spacing:1px;padding:5px 7px 3px;display:flex;align-items:center;gap:5px;}
  .srv-badge{font-size:.55rem;padding:1px 5px;border-radius:3px;font-weight:700;}
  .srv-vn{background:rgba(108,99,255,.2);color:var(--accent2);}
  .srv-va{background:rgba(245,158,66,.15);color:var(--tv);}
  .srv-vr{background:rgba(56,189,248,.15);color:var(--rock);}
  .srv-vz{background:rgba(192,132,252,.15);color:var(--vidzee);}

  .stream-item{display:flex;align-items:center;gap:5px;padding:6px 7px;border-radius:7px;
    cursor:pointer;border:1px solid transparent;transition:all .12s;}
  .stream-item:hover{background:var(--surface);border-color:var(--border);}
  .stream-item.active{background:#1a1535;border-color:var(--accent);}
  .type-tag{font-size:.58rem;font-weight:700;border-radius:4px;padding:2px 5px;white-space:nowrap;flex-shrink:0;}
  .tag-hls{background:#2a1f0a;color:var(--warn);}
  .tag-mp4{background:#0a2a14;color:var(--ok);}
  .tag-dash{background:#1a0a2a;color:#c084fc;}
  .tag-txt{background:#1a1535;color:var(--accent2);}
  .tag-embed{background:#0a1f2a;color:#38bdf8;}
  .tag-playlist{background:#1a1535;color:var(--accent2);}
  .tag-mirror{background:var(--surface2);color:var(--muted);}
  .tag-rock{background:#0a1a24;color:var(--rock);}
  .tag-vidzee{background:#1a0a2a;color:var(--vidzee);}
  .stream-url-text{font-size:.63rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0;}
  .stream-item.active .stream-url-text{color:var(--accent2);}
  .play-icon{flex-shrink:0;color:var(--accent);font-size:.72rem;opacity:0;}
  .stream-item:hover .play-icon,.stream-item.active .play-icon{opacity:1;}
  .copy-icon{flex-shrink:0;font-size:.65rem;color:var(--muted);opacity:0;cursor:pointer;padding:2px 4px;border-radius:3px;}
  .stream-item:hover .copy-icon{opacity:1;}
  .copy-icon:hover{color:var(--ok);}

  ::-webkit-scrollbar{width:4px;}
  ::-webkit-scrollbar-track{background:transparent;}
  ::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
</style>
</head>
<body>

<header>
  <div class="logo-dot">▶</div>
  <h1>Stream Player</h1>
  <span id="hdr-status">idle</span>
</header>

<div class="wrap">
  <!-- LEFT -->
  <div class="player-side">
    <div class="url-bar">
      <input id="manualUrl" placeholder="Paste m3u8 / mp4 / mpd / embed URL…" />
      <select id="manualType" title="Force type">
        <option value="auto">Auto</option>
        <option value="hls">HLS</option>
        <option value="mp4">MP4</option>
        <option value="dash">DASH</option>
        <option value="txt">TXT</option>
        <option value="embed">Embed</option>
      </select>
      <button onclick="playManual()">▶ Play</button>
    </div>

    <div>
      <div class="adv-toggle" id="advToggle" onclick="toggleAdv()">
        <span class="arr">▶</span> Advanced headers
      </div>
      <div class="adv-section" id="advSection">
        <div class="adv-row">
          <label>Referer</label>
          <input id="adv-referer" type="url" placeholder="https://example.com/" />
        </div>
        <div class="adv-row">
          <label>Origin</label>
          <input id="adv-origin" type="url" placeholder="https://example.com" />
        </div>
        <div class="adv-note">Headers injected into every HLS segment and manifest XHR request.</div>
      </div>
    </div>

    <div class="media-wrap">
      <video id="vid" controls></video>
      <iframe id="iframe-player" allowfullscreen allow="autoplay; fullscreen; encrypted-media"></iframe>
      <div class="video-overlay" id="overlay">
        <div class="spinner" id="spinner" style="display:none"></div>
        <div class="overlay-msg" id="overlayMsg">Select a stream or paste a URL above</div>
      </div>
    </div>

    <div class="status-bar" id="statusBar">
      <span><span class="dot warn"></span>No stream loaded</span>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="source-panel">
    <div class="panel-head">
      <h2>Sources</h2>
      <span class="ph-cnt" id="totalBadge">0</span>
      <div class="fetch-bar">
        <input id="g-tmdb" type="number" placeholder="TMDB ID" value="280" />
        <select id="g-mtype">
          <option value="movie">Movie</option>
          <option value="tv">TV</option>
        </select>
        <button id="g-btn" onclick="fetchAll()">⚡ Fetch All</button>
      </div>
    </div>

    <!-- Episode selector with Manual + Absolute modes -->
    <div class="ep-strip" id="ep-strip">
      <div class="ep-mode-tabs">
        <button class="ep-mode-tab active" id="tab-manual" onclick="setEpMode('manual')">Season / Ep</button>
        <button class="ep-mode-tab" id="tab-abs" onclick="setEpMode('abs')">Absolute Ep#</button>
      </div>

      <!-- Manual mode -->
      <div id="ep-manual-block">
        <div class="ep-manual-row">
          <input id="g-season"  type="number" placeholder="Season"  value="1" min="1"/>
          <input id="g-episode" type="number" placeholder="Episode" value="1" min="1"/>
        </div>
      </div>

      <!-- Absolute episode mode -->
      <div id="ep-abs-block" style="display:none;">
        <div class="ep-abs-row">
          <input id="g-abs-ep" type="number" placeholder="Absolute episode number (e.g. 399)" min="1"/>
          <button id="detect-btn" onclick="detectEpisode()">🔍 Detect</button>
        </div>
        <div class="ep-detect-result" id="detect-result"></div>
        <div class="ep-detect-err"   id="detect-err"></div>
      </div>
    </div>

    <div class="src-chips">
      <div class="src-chip" id="chip-vn"><span class="chip-dot"></span>VidNest</div>
      <div class="src-chip" id="chip-va"><span class="chip-dot"></span>VAPlayer</div>
      <div class="src-chip" id="chip-vr"><span class="chip-dot"></span>VidRock</div>
      <div class="src-chip" id="chip-vz"><span class="chip-dot"></span>Vidzee</div>
    </div>

    <div class="filter-tabs" id="filterTabs">
      <div class="filter-tab active" data-src="all"      onclick="filterBy(this)">All</div>
      <div class="filter-tab"        data-src="vidnest"  onclick="filterBy(this)">⚡ VidNest</div>
      <div class="filter-tab"        data-src="vaplayer" onclick="filterBy(this)">🎬 VAPlayer</div>
      <div class="filter-tab"        data-src="vidrock"  onclick="filterBy(this)">🪨 VidRock</div>
      <div class="filter-tab"        data-src="vidzee"   onclick="filterBy(this)">🔮 Vidzee</div>
    </div>

    <div class="stream-list" id="streamList"></div>
  </div>
</div>

<script>
'use strict';

// ── TMDB API key ──────────────────────────────────────────────────
const TMDB_API_KEY = '6fad3f86b8452ee232deb7977d7dcf58';
const TMDB_BASE    = 'https://api.themoviedb.org/3';

// ── Global state ──────────────────────────────────────────────────
let hlsPlayer    = null;
let activeItem   = null;
let activeFilter = 'all';
let allStreams    = [];
let epMode       = 'manual'; // 'manual' | 'abs'

// ── Episode mode toggle ───────────────────────────────────────────
function setEpMode(mode) {
  epMode = mode;
  document.getElementById('tab-manual').classList.toggle('active', mode === 'manual');
  document.getElementById('tab-abs').classList.toggle('active', mode === 'abs');
  document.getElementById('ep-manual-block').style.display = mode === 'manual' ? '' : 'none';
  document.getElementById('ep-abs-block').style.display    = mode === 'abs'    ? '' : 'none';
  clearDetectResult();
}

function clearDetectResult() {
  var r = document.getElementById('detect-result');
  var e = document.getElementById('detect-err');
  r.className = 'ep-detect-result';
  e.className = 'ep-detect-err';
  r.textContent = '';
  e.textContent = '';
}

// ── TMDB: resolve absolute episode → season + episode ────────────
async function tmdbGetAllSeasons(tmdbId) {
  const url = TMDB_BASE + '/tv/' + tmdbId + '?api_key=' + TMDB_API_KEY;
  const res = await fetch(url, { signal: AbortSignal.timeout(10000) });
  if (!res.ok) throw new Error('TMDB HTTP ' + res.status);
  const data = await res.json();
  // Filter out specials (season 0) and return sorted
  const seasons = (data.seasons || []).filter(function(s){ return s.season_number > 0; });
  seasons.sort(function(a, b){ return a.season_number - b.season_number; });
  return seasons;
}

async function tmdbGetSeasonEpisodeCount(tmdbId, seasonNum) {
  const url = TMDB_BASE + '/tv/' + tmdbId + '/season/' + seasonNum + '?api_key=' + TMDB_API_KEY;
  const res = await fetch(url, { signal: AbortSignal.timeout(10000) });
  if (!res.ok) return 0;
  const data = await res.json();
  return (data.episodes && data.episodes.length) || 0;
}

// Given absolute episode number, walk through seasons until we find it
async function resolveAbsoluteEpisode(tmdbId, absEp) {
  absEp = parseInt(absEp, 10);
  if (!absEp || absEp < 1) throw new Error('Invalid episode number');

  const seasons = await tmdbGetAllSeasons(tmdbId);
  if (!seasons.length) throw new Error('No seasons found for this show');

  let remaining = absEp;
  for (var i = 0; i < seasons.length; i++) {
    var s = seasons[i];
    // Get actual episode count from season details
    var count = await tmdbGetSeasonEpisodeCount(tmdbId, s.season_number);
    if (count === 0) count = s.episode_count || 0; // fallback
    if (remaining <= count) {
      return { season: s.season_number, episode: remaining };
    }
    remaining -= count;
  }
  throw new Error('Episode ' + absEp + ' exceeds total episodes (' + (absEp - remaining) + ' found)');
}

async function detectEpisode() {
  clearDetectResult();
  var tmdb   = document.getElementById('g-tmdb').value.trim();
  var absEp  = document.getElementById('g-abs-ep').value.trim();
  var btn    = document.getElementById('detect-btn');
  var resEl  = document.getElementById('detect-result');
  var errEl  = document.getElementById('detect-err');

  if (!tmdb) { showDetectErr('Enter a TMDB ID first'); return; }
  if (!absEp) { showDetectErr('Enter an absolute episode number'); return; }

  btn.disabled = true;
  btn.textContent = '⏳ Detecting…';
  hdrStatus('detecting episode…');

  try {
    var result = await resolveAbsoluteEpisode(tmdb, absEp);
    // Switch to manual mode and populate
    setEpMode('manual');
    document.getElementById('g-season').value  = result.season;
    document.getElementById('g-episode').value = result.episode;
    resEl.textContent = '✓ Ep ' + absEp + ' → Season ' + result.season + ', Episode ' + result.episode;
    resEl.className = 'ep-detect-result visible';
    hdrStatus('detected S' + result.season + 'E' + result.episode);
  } catch (e) {
    showDetectErr(e.message || 'Detection failed');
    hdrStatus('detection failed');
  } finally {
    btn.disabled = false;
    btn.textContent = '🔍 Detect';
  }
}

function showDetectErr(msg) {
  var errEl = document.getElementById('detect-err');
  errEl.textContent = '✗ ' + msg;
  errEl.className = 'ep-detect-err visible';
}

// ── Unified fetch ─────────────────────────────────────────────────
async function fetchAll() {
  var tmdb    = document.getElementById('g-tmdb').value.trim();
  var mtype   = document.getElementById('g-mtype').value;
  var season  = document.getElementById('g-season').value  || '1';
  var episode = document.getElementById('g-episode').value || '1';
  if (!tmdb) { hdrStatus('Enter a TMDB ID'); return; }

  // If in abs mode and not yet detected, auto-detect first
  if (mtype === 'tv' && epMode === 'abs') {
    var absEp = document.getElementById('g-abs-ep').value.trim();
    if (absEp) {
      var btn = document.getElementById('g-btn');
      btn.disabled = true;
      hdrStatus('detecting episode…');
      try {
        var result = await resolveAbsoluteEpisode(tmdb, absEp);
        setEpMode('manual');
        document.getElementById('g-season').value  = result.season;
        document.getElementById('g-episode').value = result.episode;
        season  = String(result.season);
        episode = String(result.episode);
        var resEl = document.getElementById('detect-result');
        resEl.textContent = '✓ Ep ' + absEp + ' → Season ' + result.season + ', Episode ' + result.episode;
        resEl.className = 'ep-detect-result visible';
        hdrStatus('detected S' + result.season + 'E' + result.episode);
      } catch (e) {
        showDetectErr(e.message || 'Detection failed');
        hdrStatus('detection failed');
        btn.disabled = false;
        return;
      }
    }
  }

  clearAll();
  document.getElementById('g-btn').disabled = true;
  hdrStatus('fetching…');
  setChip('vn','pending'); setChip('va','pending');
  setChip('vr','pending'); setChip('vz','pending');

  await Promise.all([
    fetchVidnest (tmdb, mtype, season, episode),
    fetchVaplayer(tmdb, mtype, season, episode),
    fetchVidrock (tmdb, mtype, season, episode),
    fetchVidzee  (tmdb, mtype, season, episode),
  ]);

  document.getElementById('totalBadge').textContent = allStreams.length;
  hdrStatus(allStreams.length ? allStreams.length + ' streams' : 'no results');
  document.getElementById('g-btn').disabled = false;
}

document.getElementById('g-mtype').addEventListener('change', function () {
  var isTv = this.value === 'tv';
  document.getElementById('ep-strip').classList.toggle('visible', isTv);
  if (!isTv) clearDetectResult();
});

// ── VidNest ───────────────────────────────────────────────────────
const ALPHA = 'RB0fpH8ZEyVLkv7c2i6MAJ5u3IKFDxlS1NTsnGaqmXYdUrtzjwObCgQP94hoeW+/=';
const VN_SERVERS = {
  catflix:'movies4f', ophim:'klikxxi',    alfa:'moviesapi',
  beta:'purstream',   lamda:'allmovies',  prime:'catflix',
  hexa:'vidlink',     sigma:'hollymoviehd', gama:'flixhq', delta:'allmovies',
};
const PROXY_LIST = [
  { name:'corsproxy.io', wrap: function(u){ return 'https://corsproxy.io/?url=' + encodeURIComponent(u); } },
  { name:'allorigins',   wrap: function(u){ return 'https://api.allorigins.win/raw?url=' + encodeURIComponent(u); } },
  { name:'codetabs',     wrap: function(u){ return 'https://api.codetabs.com/v1/proxy?quest=' + encodeURIComponent(u); } },
  { name:'thingproxy',   wrap: function(u){ return 'https://thingproxy.freeboard.io/fetch/' + u; } },
];
const SUB_HOSTS = ['opensubtitles.org','opensubtitles.com','wyzie.io','vdrk.site'];
const SUB_EXTS  = ['.vtt','.srt','.ass','.ssa'];
let vnProxy = null;

function vnDecode(data) {
  var val = {};
  for (var i = 0; i < ALPHA.length; i++) val[ALPHA[i]] = i;
  data = data.replace(/\s+/g, '');
  var out = [];
  for (var i = 0; i < data.length; i += 4) {
    var chunk = (data.slice(i, i+4) + '====').slice(0, 4);
    var n = chunk.split('').map(function(c){ return val[c] !== undefined ? val[c] : 64; });
    out.push((n[0] << 2) | (n[1] >> 4));
    if (n[2] !== 64) out.push(((n[1] & 15) << 4) | (n[2] >> 2));
    if (n[3] !== 64) out.push(((n[2] & 3) << 6) | n[3]);
  }
  return JSON.parse(new TextDecoder().decode(new Uint8Array(out)));
}
function isSub(url) {
  var u = url.toLowerCase();
  return SUB_HOSTS.some(function(h){ return u.includes(h); }) || SUB_EXTS.some(function(e){ return u.split('?')[0].endsWith(e); });
}
function vnExtractUrls(obj, found) {
  found = found || [];
  if (!obj || typeof obj !== 'object') return found;
  if (Array.isArray(obj)) { obj.forEach(function(v){ vnExtractUrls(v, found); }); return found; }
  for (var k in obj) {
    var v = obj[k];
    if ((k === 'url' || k === 'file') && typeof v === 'string' && v.startsWith('http')) {
      if (!isSub(v)) found.push(vnTransform(v));
    } else vnExtractUrls(v, found);
  }
  return found;
}
function vnTransform(url) {
  try {
    var u = new URL(url);
    if (u.hostname === 'goodstream.cc') {
      var s = u.pathname.split('/').filter(Boolean);
      if ((s[0] === 'streamsvr' || s[0] === 'pl') && s[1])
        return u.protocol + '//' + u.hostname + '/embed/' + s[1];
    }
  } catch(e) {}
  return url;
}
async function vnProbeProxy(p) {
  try {
    var r = await fetch(p.wrap('https://new.vidnest.fun/moviesapi/movie/254'), { signal: AbortSignal.timeout(8000) });
    if (!r.ok) return false;
    return !!(await r.json()).data;
  } catch(e) { return false; }
}
async function vnFindProxy() {
  for (var i = 0; i < PROXY_LIST.length; i++) {
    if (await vnProbeProxy(PROXY_LIST[i])) { vnProxy = PROXY_LIST[i]; return true; }
  }
  return false;
}
async function vnFetchServer(backend, path) {
  var r = await fetch(vnProxy.wrap('https://new.vidnest.fun/' + backend + '/' + path), { signal: AbortSignal.timeout(14000) });
  if (!r.ok) throw new Error('HTTP ' + r.status);
  var raw = await r.json();
  if (!raw || !raw.data) throw new Error('no data');
  return vnExtractUrls(vnDecode(raw.data));
}
async function fetchVidnest(tmdb, mtype, season, episode) {
  var path = mtype === 'movie' ? 'movie/' + tmdb : 'tv/' + tmdb + '/' + season + '/' + episode;
  try {
    if (!vnProxy && !await vnFindProxy()) throw new Error('All proxies failed');
    var jobs = Object.entries(VN_SERVERS).map(async function(entry) {
      var name = entry[0], backend = entry[1];
      try {
        var urls = await vnFetchServer(backend, path);
        return { server: name, urls: urls };
      } catch(e) { return null; }
    });
    var results = (await Promise.all(jobs)).filter(function(r){ return r && r.urls.length; });
    var added = 0;
    results.forEach(function(res) {
      res.urls.forEach(function(url) {
        var t = detectType(url);
        pushStream({ source:'vidnest', server: res.server, pill: t, label: t.toUpperCase(), url: url, type: t });
        added++;
      });
    });
    setChip('vn', added ? 'done' : 'err');
  } catch(e) {
    console.warn('[VidNest]', e);
    setChip('vn', 'err');
  }
}

// ── VAPlayer ──────────────────────────────────────────────────────
const VA_API   = 'https://streamdata.vaplayer.ru/api.php';
const VA_EMBED = 'https://vaplayer.ru/embed';
const VA_PROXY = 'https://corsproxy.io/?url=';

function vaIsPlaylist(url) { return url.indexOf('/playlist/') !== -1 || url.indexOf('list.m3u8') !== -1; }

async function fetchVaplayer(tmdb, mtype, season, episode) {
  try {
    var apiUrl   = mtype === 'movie'
      ? VA_API + '?tmdb=' + tmdb + '&type=movie'
      : VA_API + '?tmdb=' + tmdb + '&type=tv&season=' + season + '&episode=' + episode;
    var embedUrl = mtype === 'movie'
      ? VA_EMBED + '/movie/' + tmdb
      : VA_EMBED + '/tv/' + tmdb + '/' + season + '/' + episode;
    var res = await fetch(VA_PROXY + encodeURIComponent(apiUrl), {
      headers: { 'Referer': 'https://vaplayer.ru/', 'Origin': 'https://vaplayer.ru', 'Accept': 'application/json,*/*' }
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    var json = await res.json();
    if (json.status_code !== '200') throw new Error('API error');
    var raw = (json.data && json.data.stream_urls) || [];
    pushStream({ source:'vaplayer', server:'VAPlayer', pill:'embed', label:'Embed', url: embedUrl, type:'embed' });
    var mc = 0;
    raw.forEach(function(url) {
      var pl = vaIsPlaylist(url);
      if (!pl) mc++;
      pushStream({ source:'vaplayer', server:'VAPlayer', pill: pl ? 'playlist' : 'mirror', label: pl ? 'Playlist' : 'Mirror ' + mc, url: url, type:'hls' });
    });
    if (json.thumbnails_url)
      pushStream({ source:'vaplayer', server:'VAPlayer', pill:'txt', label:'VTT', url: json.thumbnails_url, type:'txt' });
    setChip('va', 'done');
  } catch(e) {
    console.warn('[VAPlayer]', e);
    setChip('va', 'err');
  }
}

// ── VidRock ───────────────────────────────────────────────────────
const VR_KEY   = 'x7k9mPqT2rWvY8zA5bC3nF6hJ2lK4mN9';
const VR_API   = 'https://vidrock.ru/api';
const VR_EMBED = 'https://vidrock.ru/embed';

async function vrAesEncrypt(plain) {
  var keyBytes = new TextEncoder().encode(VR_KEY);
  var iv = keyBytes.slice(0, 16);
  var pb = new TextEncoder().encode(plain);
  var padLen = 16 - (pb.length % 16);
  var padded = new Uint8Array(pb.length + padLen);
  padded.set(pb); padded.fill(padLen, pb.length);
  var key = await crypto.subtle.importKey('raw', keyBytes, { name:'AES-CBC' }, false, ['encrypt']);
  var enc = await crypto.subtle.encrypt({ name:'AES-CBC', iv: iv }, key, padded);
  return btoa(String.fromCharCode.apply(null, new Uint8Array(enc)))
    .replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
}
async function fetchVidrock(tmdb, mtype, season, episode) {
  try {
    var plain    = mtype === 'tv' ? tmdb + '_' + season + '_' + episode : tmdb;
    var token    = await vrAesEncrypt(plain);
    var apiUrl   = VR_API + '/' + mtype + '/' + token;
    var embedUrl = mtype === 'movie'
      ? VR_EMBED + '/movie/' + tmdb
      : VR_EMBED + '/tv/' + tmdb + '/' + season + '/' + episode;
    var res = await fetch(apiUrl, {
      headers: {
        'Referer': embedUrl,
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
      },
      signal: AbortSignal.timeout(15000),
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    var data = await res.json();
    var streams = Object.entries(data).filter(function(e){ return e[1] && e[1].url; });
    if (!streams.length) throw new Error('No streams');
    pushStream({ source:'vidrock', server:'VidRock', pill:'embed', label:'Embed', url: embedUrl, type:'embed' });
    streams.forEach(function(e) {
      var t = detectType(e[1].url);
      pushStream({ source:'vidrock', server:'VidRock', pill:'rock', label: e[0], url: e[1].url, type: t });
    });
    setChip('vr', 'done');
  } catch(e) {
    console.warn('[VidRock]', e);
    setChip('vr', 'err');
  }
}

// ── Vidzee ────────────────────────────────────────────────────────
const VZ_SECRET  = 'c4a8f1d7e2b9a6c3d0f5e8a1b7c4d9e2';
const VZ_PROXY   = 'https://vixsrcproxy2.khantara922.workers.dev/';
const VZ_SERVERS = [
  {sr:'0',name:'Tcloud'},{sr:'1',name:'IpCloud'},{sr:'2',name:'Achilles'},
  {sr:'3',name:'Nflix'}, {sr:'4',name:'Drag'},   {sr:'5',name:'Viet'},
  {sr:'6',name:'Hindi'}, {sr:'7',name:'Hindi_v2'},
];
let vzRuntimeKey = null;

async function vzProxyFetch(url) {
  var r = await fetch(VZ_PROXY + '?url=' + encodeURIComponent(url), { signal: AbortSignal.timeout(15000) });
  if (!r.ok) throw new Error('proxy ' + r.status);
  return r.text();
}
async function vzDecryptApiKey(b64) {
  var raw = Uint8Array.from(atob(b64.trim()), function(c){ return c.charCodeAt(0); });
  var nonce = raw.slice(0,12), tag = raw.slice(12,28), cipher = raw.slice(28);
  var ctWithTag = new Uint8Array(cipher.length + tag.length);
  ctWithTag.set(cipher); ctWithTag.set(tag, cipher.length);
  var keyBuf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(VZ_SECRET));
  var key    = await crypto.subtle.importKey('raw', keyBuf, { name:'AES-GCM' }, false, ['decrypt']);
  var plain  = await crypto.subtle.decrypt({ name:'AES-GCM', iv: nonce }, key, ctWithTag);
  return new TextDecoder().decode(plain);
}
function vzDecryptLink(encLink, rk) {
  var decoded  = atob(encLink);
  var parts    = decoded.split(':');
  var ivB64 = parts[0], ctB64 = parts[1];
  var keyBytes = rk.slice(0, 32).padEnd(32, '\0');
  var key = CryptoJS.enc.Utf8.parse(keyBytes);
  var iv  = CryptoJS.enc.Base64.parse(ivB64);
  var ct  = CryptoJS.enc.Base64.parse(ctB64);
  var dec = CryptoJS.AES.decrypt({ ciphertext: ct }, key, { iv: iv, mode: CryptoJS.mode.CBC, padding: CryptoJS.pad.Pkcs7 });
  return dec.toString(CryptoJS.enc.Utf8);
}
async function fetchVidzee(tmdb, mtype, season, episode) {
  try {
    var embedUrl = 'https://player.vidzee.wtf/embed/' + mtype + '/' + tmdb;
    if (!vzRuntimeKey) {
      var raw = await vzProxyFetch('https://core.vidzee.wtf/api-key');
      vzRuntimeKey = await vzDecryptApiKey(raw.replace(/\s+/g, ''));
    }
    pushStream({ source:'vidzee', server:'Vidzee', pill:'embed', label:'Embed', url: embedUrl, type:'embed' });
    var seen = new Set();
    var jobs = VZ_SERVERS.map(async function(srv) {
      var apiUrl = 'https://player.vidzee.wtf/api/server?id=' + encodeURIComponent(tmdb) + '&sr=' + srv.sr;
      if (mtype === 'tv' && season && episode) apiUrl += '&ss=' + season + '&ep=' + episode;
      try {
        var text    = await vzProxyFetch(apiUrl);
        var payload = JSON.parse(text);
        if (payload && payload.error) return;
        ((payload && payload.url) || []).forEach(function(item) {
          var enc = item && item.link;
          if (!enc) return;
          try {
            var dec = vzDecryptLink(enc, vzRuntimeKey);
            if (!dec || seen.has(dec)) return;
            seen.add(dec);
            var t = detectType(dec);
            pushStream({ source:'vidzee', server:'Vidzee·' + srv.name, pill:'vidzee', label: srv.name, url: dec, type: t });
          } catch(e) {}
        });
      } catch(e) {}
    });
    await Promise.all(jobs);
    setChip('vz', 'done');
  } catch(e) {
    console.warn('[Vidzee]', e);
    setChip('vz', 'err');
  }
}

// ── Stream list ───────────────────────────────────────────────────
const SRC_BADGE = { vidnest:'srv-vn', vaplayer:'srv-va', vidrock:'srv-vr', vidzee:'srv-vz' };
const SRC_NAME  = { vidnest:'VidNest', vaplayer:'VAPlayer', vidrock:'VidRock', vidzee:'Vidzee' };

function pushStream(s) {
  allStreams.push(s);
  if (activeFilter === 'all' || activeFilter === s.source) renderItem(s);
  document.getElementById('totalBadge').textContent = allStreams.length;
}

function renderItem(s) {
  var list  = document.getElementById('streamList');
  var grpId = 'grp-' + s.source + '-' + s.server.replace(/[^a-z0-9]/gi, '_');
  var group = document.getElementById(grpId);
  if (!group) {
    group = document.createElement('div');
    group.className = 'server-group';
    group.id = grpId;
    var lbl = document.createElement('div');
    lbl.className = 'server-label';
    var bc = SRC_BADGE[s.source] || '';
    var sn = SRC_NAME[s.source]  || s.source;
    lbl.innerHTML = '<span class="srv-badge ' + bc + '">' + esc(sn) + '</span>' + esc(s.server);
    group.appendChild(lbl);
    list.appendChild(group);
  }
  var item = document.createElement('div');
  item.className = 'stream-item';
  item.dataset.source = s.source;
  item.dataset.url    = s.url;
  item.innerHTML =
    '<span class="type-tag tag-' + s.pill + '">' + esc(s.label) + '</span>' +
    '<span class="stream-url-text" title="' + esc(s.url) + '">' + esc(s.url) + '</span>' +
    '<span class="copy-icon" title="Copy URL">⎘</span>' +
    '<span class="play-icon">▶</span>';
  item.querySelector('.copy-icon').addEventListener('click', function(e) {
    e.stopPropagation(); copyUrl(s.url, this);
  });
  item.addEventListener('click', function() { playStream(s.url, s.type, item); });
  group.appendChild(item);
}

function clearAll() {
  allStreams = [];
  document.getElementById('streamList').innerHTML = '';
  document.getElementById('totalBadge').textContent = '0';
  ['vn','va','vr','vz'].forEach(function(k){ setChip(k, ''); });
}

function filterBy(tabEl) {
  activeFilter = tabEl.dataset.src;
  document.querySelectorAll('.filter-tab').forEach(function(t){ t.classList.remove('active'); });
  tabEl.classList.add('active');
  document.getElementById('streamList').innerHTML = '';
  var toShow = activeFilter === 'all' ? allStreams : allStreams.filter(function(s){ return s.source === activeFilter; });
  toShow.forEach(renderItem);
  if (activeItem) {
    var url = activeItem.dataset.url;
    document.querySelectorAll('.stream-item').forEach(function(el) {
      if (el.dataset.url === url) { el.classList.add('active'); activeItem = el; }
    });
  }
}

// ── Media loading ─────────────────────────────────────────────────
function detectType(url) {
  var u = url.toLowerCase().split('?')[0];
  if (u.endsWith('.mp4') || u.endsWith('.webm') || u.endsWith('.mkv')) return 'mp4';
  if (u.endsWith('.mpd'))  return 'dash';
  if (u.endsWith('.txt'))  return 'txt';
  if (isEmbedUrl(url))     return 'embed';
  return 'hls';
}
function isEmbedUrl(url) {
  try {
    var h = new URL(url).hostname;
    var hosts = [
      'goodstream.cc','vidlink.pro','vidsrc.to','vidsrc.me','vidsrc.xyz',
      'embed.su','multiembed.mov','2embed.cc','smashystream.com','moviesapi.club',
      'vidfast.pro','vidnest.fun','warezcdn.link','frembed.hair','filemoon.sx',
      'vaplayer.ru','vidrock.ru','vidzee.wtf',
    ];
    if (hosts.some(function(e){ return h.includes(e); })) return true;
    if (new URL(url).pathname.includes('/embed/')) return true;
  } catch(e) {}
  return false;
}
function getHeaders() {
  return {
    referer: document.getElementById('adv-referer').value.trim(),
    origin:  document.getElementById('adv-origin').value.trim(),
  };
}

function playStream(url, type, itemEl) {
  if (activeItem) activeItem.classList.remove('active');
  activeItem = itemEl;
  itemEl.classList.add('active');
  document.getElementById('manualUrl').value = url;
  loadMedia(url, type);
}
function playManual() {
  var url = document.getElementById('manualUrl').value.trim();
  if (!url) return;
  var type = document.getElementById('manualType').value;
  if (type === 'auto') type = detectType(url);
  if (activeItem) { activeItem.classList.remove('active'); activeItem = null; }
  loadMedia(url, type);
}
async function loadMedia(url, type) {
  showOverlay(true, 'Loading…');
  setStatus('warn', 'Loading ' + type.toUpperCase() + '…', url);
  destroyPlayer();
  if (type === 'txt')   { await loadTxt(url); return; }
  if (type === 'embed') { loadEmbed(url);     return; }
  if (type === 'mp4' || type === 'webm') { loadNative(url, type); return; }
  if (type === 'dash')  { loadDash(url);      return; }
  loadHls(url);
}
function destroyPlayer() {
  if (hlsPlayer) { hlsPlayer.destroy(); hlsPlayer = null; }
  var vid = document.getElementById('vid');
  var ifr = document.getElementById('iframe-player');
  vid.pause(); vid.removeAttribute('src'); vid.load();
  vid.style.display = 'block';
  ifr.style.display = 'none'; ifr.src = 'about:blank';
}

function loadHls(url) {
  var vid = document.getElementById('vid');
  var headers = getHeaders();
  var referer = headers.referer, origin = headers.origin;

  if (Hls.isSupported()) {
    var cfg = { enableWorker: true, lowLatencyMode: false };
    cfg.xhrSetup = function(xhr, reqUrl) {
      if (referer) { try { xhr.setRequestHeader('Referer', referer); } catch(e){} }
      if (origin)  { try { xhr.setRequestHeader('Origin',  origin);  } catch(e){} }
    };
    hlsPlayer = new Hls(cfg);
    hlsPlayer.loadSource(url);
    hlsPlayer.attachMedia(vid);
    hlsPlayer.on(Hls.Events.MANIFEST_PARSED, function() {
      vid.play().catch(function(){});
      showOverlay(false);
      setStatus('ok', 'Playing HLS', url);
      setTypeBadge('hls');
    });
    hlsPlayer.on(Hls.Events.ERROR, function(_, data) {
      if (data.fatal) { showOverlay(false); setStatus('err', 'HLS error: ' + data.details, url); }
    });
  } else if (vid.canPlayType('application/vnd.apple.mpegurl')) {
    vid.src = url; vid.play().catch(function(){});
    vid.oncanplay = function() { showOverlay(false); setStatus('ok', 'Playing HLS (native)', url); setTypeBadge('hls'); };
    vid.onerror   = function() { showOverlay(false); setStatus('err', 'Playback error', url); };
  } else {
    showOverlay(false); setStatus('err', 'HLS not supported', url);
  }
}

function loadNative(url, type) {
  var vid = document.getElementById('vid');
  var headers = getHeaders();
  var referer = headers.referer, origin = headers.origin;
  if (referer || origin) {
    var hdrs = {};
    if (referer) hdrs['Referer'] = referer;
    if (origin)  hdrs['Origin']  = origin;
    fetch(url, { headers: hdrs })
      .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.blob(); })
      .then(function(blob) {
        var burl = URL.createObjectURL(blob);
        vid.src = burl; vid.play().catch(function(){});
        vid.oncanplay = function() { showOverlay(false); setStatus('ok', 'Playing ' + type.toUpperCase(), url); setTypeBadge(type); };
        vid.onerror   = function() { showOverlay(false); setStatus('err', 'Playback error', url); };
      })
      .catch(function(e) { showOverlay(false); setStatus('err', 'Fetch error: ' + e.message, url); });
  } else {
    vid.src = url; vid.play().catch(function(){});
    vid.oncanplay = function() { showOverlay(false); setStatus('ok', 'Playing ' + type.toUpperCase(), url); setTypeBadge(type); };
    vid.onerror   = function() { showOverlay(false); setStatus('err', 'Playback error', url); };
  }
}

function loadDash(url) {
  var vid = document.getElementById('vid');
  vid.src = url; vid.play().catch(function(){});
  vid.oncanplay = function() { showOverlay(false); setStatus('ok', 'Playing DASH', url); setTypeBadge('dash'); };
  vid.onerror   = function() { showOverlay(false); setStatus('err', 'DASH error', url); };
}

function loadEmbed(url) {
  var vid = document.getElementById('vid');
  var ifr = document.getElementById('iframe-player');
  vid.style.display = 'none';
  ifr.style.display = 'block';
  ifr.src = url;
  ifr.onload = function() { showOverlay(false); setStatus('ok', 'Embed loaded', url); setTypeBadge('embed'); };
  setTimeout(function(){ showOverlay(false); }, 4000);
}

async function loadTxt(url) {
  try {
    var text = null;
    try { var r = await fetch(url, { signal: AbortSignal.timeout(10000) }); if (r.ok) text = await r.text(); } catch(e) {}
    if (!text && vnProxy) {
      try { var r2 = await fetch(vnProxy.wrap(url), { signal: AbortSignal.timeout(10000) }); if (r2.ok) text = await r2.text(); } catch(e) {}
    }
    if (!text) throw new Error('Could not fetch file');
    var lines = text.split('\n').map(function(l){ return l.trim(); }).filter(function(l){ return l.startsWith('http'); });
    if (!lines.length) throw new Error('No URLs in file');
    lines.forEach(function(line, i) {
      var t = detectType(line);
      pushStream({ source:'txt', server:'TXT Playlist', pill: t, label: '#' + (i+1), url: line, type: t });
    });
    showOverlay(false);
    setStatus('ok', 'TXT: ' + lines.length + ' URL(s) — playing first', url);
    setTypeBadge('txt');
    loadMedia(lines[0], detectType(lines[0]));
  } catch(e) {
    showOverlay(false); setStatus('err', 'TXT error: ' + e.message, url);
  }
}

// ── UI helpers ────────────────────────────────────────────────────
function toggleAdv() {
  document.getElementById('advToggle').classList.toggle('open');
  document.getElementById('advSection').classList.toggle('visible');
}
function showOverlay(show, msg) {
  document.getElementById('spinner').style.display = show ? 'block' : 'none';
  document.getElementById('overlayMsg').textContent = msg || '';
  document.getElementById('overlay').classList.toggle('hidden', !show);
}
function setStatus(type, label, url) {
  url = url || '';
  var cls   = type === 'ok' ? 'ok' : type === 'err' ? 'err' : 'warn';
  var short = url.length > 60 ? url.slice(0, 57) + '…' : url;
  document.getElementById('statusBar').innerHTML =
    '<span><span class="dot ' + cls + '"></span>' + esc(label) + '</span>' +
    (url ? '<span id="activeBadge"></span><span style="color:var(--muted);font-size:.66rem;word-break:break-all">' + esc(short) + '</span>' : '');
}
function setTypeBadge(type) {
  var el = document.getElementById('activeBadge');
  if (!el) return;
  var m = { hls:'mb-hls', mp4:'mb-mp4', embed:'mb-embed', txt:'mb-txt', dash:'mb-dash', playlist:'mb-playlist' };
  el.className = 'mbadge ' + (m[type] || '');
  el.textContent = type.toUpperCase();
}
function setChip(key, state) {
  var el = document.getElementById('chip-' + key);
  if (el) el.className = 'src-chip ' + state;
}
function hdrStatus(msg) { document.getElementById('hdr-status').textContent = msg; }
async function copyUrl(url, btn) {
  try {
    await navigator.clipboard.writeText(url);
    var orig = btn.textContent;
    btn.textContent = '✓'; btn.style.color = 'var(--ok)';
    setTimeout(function(){ btn.textContent = orig; btn.style.color = ''; }, 1500);
  } catch(e) {}
}
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ── Auto-load from URL params ─────────────────────────────────────
(function() {
  var p = new URLSearchParams(window.location.search);
  var r = p.get('r');
  if (r) {
    var mv = r.match(/^\/movie\/(\d+)/);
    var tv = r.match(/^\/tv\/(\d+)\/(\d+)\/(\d+)/);
    if (mv) {
      document.getElementById('g-tmdb').value = mv[1];
      fetchAll();
    } else if (tv) {
      document.getElementById('g-tmdb').value    = tv[1];
      document.getElementById('g-mtype').value   = 'tv';
      document.getElementById('ep-strip').classList.add('visible');
      document.getElementById('g-season').value  = tv[2];
      document.getElementById('g-episode').value = tv[3];
      fetchAll();
    }
    return;
  }
  var tmdb = p.get('tmdb') || p.get('id');
  if (tmdb) {
    document.getElementById('g-tmdb').value = tmdb;
    if (p.get('type') === 'tv') {
      document.getElementById('g-mtype').value = 'tv';
      document.getElementById('ep-strip').classList.add('visible');
      if (p.get('season'))  document.getElementById('g-season').value  = p.get('season');
      if (p.get('episode')) document.getElementById('g-episode').value = p.get('episode');
    }
    fetchAll();
  }
})();
</script>
</body>
</html>